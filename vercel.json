{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "index.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "GOOGLE_API_KEY": "AIzaSyC3Ys3cy_ewpAfYee8_-XbKeJv38Q44hv8"
  },
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  }
}